<div class="md:mt-4 mb-4 md:mb-8 mx-auto max-w-4xl px-4">
  <div class="grid md:grid-cols-3 gap-4 my-8 md:my-12">
    <% sections.each do |section| %>
      <section class="bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-6">
        <h2 class="source-serif font-semibold text-2xl text-slate-800 dark:text-slate-200"><%= section[:title] %></h2>
        <div class="mt-4 text-slate-700 dark:text-slate-300 leading-relaxed flex flex-col gap-y-3">
          <% section[:paragraphs].each do |paragraph| %>
            <p><%= paragraph %></p>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>
