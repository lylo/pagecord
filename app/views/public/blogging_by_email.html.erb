<%# landing-page: standalone marketing / SEO page (app/views/public), not part of a user's blog %>
<%= content_for :title do %>
  Blog By Email: Your inbox is already a writing app.
<% end %>

<%= content_for :meta_description do %>
  Blog by sending an email. Pagecord works with Gmail, Outlook, Fastmail, Proton Mail, HEY, iCloud, or any email provider. Write anywhere, hit send, and publish.
<% end %>

<%= content_for :og_image do %>
  <%= dynamic_og_image_for_landing_page(title: "Your Inbox Is Already a Writing App") %>
<% end %>

<div class="md:mt-4 mb-4 md:mb-8 mx-auto max-w-4xl px-4">
  <h1 class="source-serif font-semibold text-center text-4xl md:text-6xl tracking-tight text-slate-800 dark:text-slate-200">
    Your inbox is already a writing app.
  </h1>

  <div class="md:text-xl text-base leading-relaxed text-slate-800 dark:text-slate-200 flex flex-col gap-y-4 mt-8 md:mt-12">
    <p>
      Blogging by email works because it starts where writing already happens. No dashboard, no blank CMS screen, no special app to remember.
    </p>
    <p>
      Compose a message in Gmail, Fastmail, iCloud, Proton Mail, Outlook, HEY, or any email client. Send it to your private Pagecord address. The email becomes a post.
    </p>
    <p>
      Use the web editor when you want it. Use email when you want momentum. Either way, your site gets a real post, a real URL, RSS, and an archive you own.
    </p>
  </div>

  <div class="text-center mt-8 mb-4 md:text-xl">
    <%= link_to new_signup_path do %>
      <div class="mt-2 inline-flex font-medium p-4 rounded-xl shadow-sm btn-primary text-xl">Create your free Pagecord account</div>
    <% end %>
  </div>
</div>

<div class="md:mt-4 mb-4 md:mb-8 mx-auto max-w-4xl px-4">
  <%= image_tag "public/blogging-by-email.jpg", class: "rounded-lg my-8", alt: "Screenshot of blogging via Gmail" %>
</div>

<div class="flex justify-center gap-x-8 grayscale opacity-50 mb-8 px-4">
  <%= image_tag "public/yahoo.jpg", class: "h-10 sm:h-16 rounded-md", alt: "Yahoo logo" %>
  <%= image_tag "public/gmail.webp", class: "h-10 sm:h-16 rounded-md", alt: "Gmail logo" %>
  <%= image_tag "public/fastmail.webp", class: "h-10 sm:h-16 rounded-md", alt: "Fastmail logo" %>
  <%= image_tag "public/outlook.webp", class: "h-10 sm:h-16 rounded-md", alt: "Outlook logo" %>
  <%= image_tag "public/protonmail.webp", class: "h-10 sm:h-16 rounded-md", alt: "Proton Mail logo" %>
</div>

<%= render "landing_examples",
  examples: [
    { name: "Noodlings", url: "https://noodlings.pagecord.com/what-s-so-great-about-posting-by-email", description: "A Pagecord post about why publishing from email feels so different." },
    { name: "Focustivity", url: "https://focustivity.blog", description: "A personal blog where quick publishing helps posts make it out of drafts." },
    { name: "Chad Moore", url: "https://blog.chadmoore.net/", description: "A custom-domain blog where email makes writing and publishing feel frictionless." }
  ],
  testimonials: [
    { name: "Eric", url: "https://focustivity.blog", quote: "I was drawn to Pagecord because it allows me to post simply by sending an email. I was blown away by the other great features." },
    { name: "Chad", url: "https://blog.chadmoore.net/", quote: "The ability to post by email was such a relief. Write, send, publish. Frictionless!" }
  ] %>
