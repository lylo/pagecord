<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Pagecord",
  "url": "https://pagecord.com",
  "description": "A minimalist blogging platform for independent writers. Post by email or use the rich text editor. Create your home page and blog in seconds.",
  "applicationCategory": "BloggingApplication",
  "operatingSystem": "Any (web-based)",
  "offers": [
    {
      "@type": "Offer",
      "name": "Classic",
      "price": "0",
      "priceCurrency": "USD"
    },
    {
      "@type": "Offer",
      "name": "Premium (Annual)",
      "price": "<%= Subscription.price(:annual) %>",
      "priceCurrency": "USD",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "billingDuration": "P1Y"
      }
    },
    {
      "@type": "Offer",
      "name": "Premium (Monthly)",
      "price": "<%= Subscription.price(:monthly) %>",
      "priceCurrency": "USD",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "billingDuration": "P1M"
      }
    }
  ]
}
</script>

<div class="md:mt-4 mb-4 md:mb-8 mx-auto max-w-4xl px-4">
  <h1 class="source-serif font-semibold text-center text-4xl md:text-6xl tracking-tight">
  Blog Without The Slog
  </h1>

  <div class="md:text-xl text-base leading-relaxed text-slate-800 dark:text-slate-200 flex flex-col gap-y-4">
    <p class="mt-8 md:mt-12 text-2xl font-bold"><span class="inline bg-[linear-gradient(180deg,transparent_65%,rgb(79_189_156_/_0.3)_65%)] dark:bg-[linear-gradient(180deg,transparent_65%,rgb(79_189_156_/_0.4)_65%)] [box-decoration-break:clone] px-1 -mx-1 leading-relaxed">Create your home page and blog in seconds. Then just write.</span></p>

    <p>A powerful editor when you need it, post by email when you don't.</p>

    <p>Pagecord is independent, open source, and built to last. Own your corner of the web.</span></p>

    <p>Classic sites are <strong>free forever</strong>. Premium is only $<%= localised_price %>/year or $<%= localised_price(:monthly) %>/month.</p>

    <div class="text-center mt-2 mb-4 md:text-xl">
      <%= link_to new_signup_path do %>
        <div class="mt-2 inline-flex font-medium p-4 rounded-xl shadow-sm btn-primary text-xl">Start writing for free</div>
      <% end %>
      <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">Trusted by 700+ independent bloggers</p>
    </div>

    <p>
    Check out real sites: <a href="https://olly.world" class="home-link">Olly's home page</a>, <a href="https://dhester.me/" class="home-link">Darren's blog</a>, <a href="https://jan.fyi/" class="home-link">jan.fyi</a> or use the shuffle feature to <a href="/shuffle" class="home-link">discover a random blog</a>.
    </p>
   </div>
</div>

<%= render "public/screenshots" %>

<!-- Video Section -->
<div id="walkthrough" class="mt-16 mb-4 md:mb-8 mx-auto max-w-4xl px-4 text-slate-800 dark:text-slate-200">
