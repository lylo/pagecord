<div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden mb-6">
  <div class="bg-slate-50 dark:bg-slate-700/50 border-b border-slate-200 dark:border-slate-700 px-6 py-4">
    <div class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <%= link_to blog_home_url(@blog), target: "_blank", class: "font-semibold text-slate-900 dark:text-slate-50 hover:underline" do %>
          @<%= @blog.subdomain %>
        <% end %>
        <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= @spam_detection.spam? ? 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400' : 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400' %>">
          <%= @spam_detection.status.titleize %>
        </span>
        <%= link_to "User profile", admin_user_path(@blog.user), class: "text-xs text-slate-500 dark:text-slate-400 hover:underline" %>
      </div>
      <span class="text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap">Detected <%= @spam_detection.detected_at&.to_formatted_s(:long) %></span>
    </div>
  </div>

  <div class="p-6">
    <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-2">Detection Reason</h3>
    <p class="text-sm text-slate-700 dark:text-slate-300 mb-6"><%= @spam_detection.reason %></p>

    <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-2">Blog Content</h3>
    <dl class="space-y-3 text-sm">
      <div class="flex justify-between gap-4">
        <dt class="font-medium text-slate-900 dark:text-slate-50">Title</dt>
        <dd class="text-slate-500 dark:text-slate-400"><%= @blog.title.presence || "(none)" %></dd>
      </div>
      <div>
        <dt class="font-medium text-slate-900 dark:text-slate-50 mb-1">Bio</dt>
        <dd class="text-slate-500 dark:text-slate-400"><%= @blog.bio.to_plain_text.presence || "(empty)" %></dd>
      </div>
    </dl>
  </div>
</div>

<% posts = @blog.posts.published.order(published_at: :desc).limit(5) %>
<% if posts.any? %>
  <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden mb-6">
    <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-700/50 px-6 py-3 border-b border-slate-200 dark:border-slate-700">Recent Posts</h3>
    <div class="divide-y divide-slate-200 dark:divide-slate-700">
      <% posts.each do |post| %>
        <div class="px-6 py-4">
          <div class="font-medium text-sm text-slate-900 dark:text-slate-50"><%= post.display_title %></div>
          <div class="text-sm text-slate-500 dark:text-slate-400 mt-1"><%= post.text_summary.to_s.truncate(150) %></div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="flex items-center justify-between">
  <%= link_to "← Back", admin_moderation_spam_index_path, class: "btn-optional py-1.5" %>
  <div class="flex gap-2">
    <% unless @spam_detection.reviewed? %>
      <%= button_to "Mark Clean",
          dismiss_admin_moderation_spam_path(@spam_detection),
          method: :post,
          class: "btn-primary py-1.5" %>
      <%= button_to "Confirm Spam",
          confirm_admin_moderation_spam_path(@spam_detection),
          method: :post,
          class: "btn-danger py-1.5" %>
    <% end %>
  </div>
</div>
