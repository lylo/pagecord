<div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden mb-6">
  <div class="bg-slate-50 dark:bg-slate-700/50 border-b border-slate-200 dark:border-slate-700 px-6 py-3 flex items-center justify-between">
    <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Overview</h3>
    <%= link_to new_admin_user_path, class: "w-6 h-6 rounded-full border border-slate-300 dark:border-slate-600 flex items-center justify-center text-slate-500 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors", title: "Create new user" do %>
      <%= inline_svg_tag "icons/plus.svg", class: "w-4 h-4" %>
    <% end %>
  </div>
  <div class="px-6 py-5">
    <div class="flex items-center gap-8 mb-4">
      <%= link_to admin_blogs_path, class: "group" do %>
        <span class="text-2xl font-bold text-slate-900 dark:text-slate-50 group-hover:underline"><%= number_with_delimiter(@total_users) %></span>
        <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wide ml-1">Users</span>
      <% end %>
      <span class="text-slate-200 dark:text-slate-700">|</span>
      <%= link_to admin_blogs_path(status: "paid"), class: "group" do %>
        <span class="text-2xl font-bold text-slate-900 dark:text-slate-50 group-hover:underline"><%= number_with_delimiter(Subscription.active_paid.count) %></span>
        <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wide ml-1">Paid</span>
      <% end %>
      <span class="text-slate-200 dark:text-slate-700">|</span>
      <%= link_to admin_blogs_path(status: "comped"), class: "group" do %>
        <span class="text-2xl font-bold text-slate-900 dark:text-slate-50 group-hover:underline"><%= number_with_delimiter(Subscription.comped.count) %></span>
        <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wide ml-1">Comped</span>
      <% end %>
    </div>

    <%= form_with url: admin_blogs_path, method: :get, data: { turbo_frame: "stats-content", controller: "search", search_target: "form" }, local: true do |form| %>
      <div class="relative">
        <%= form.text_field :search, placeholder: "Search by subdomain or email...", value: params[:search],
            class: "form-field w-full px-3 py-2 pr-10 text-sm",
            data: { action: "input->search#search keydown->search#handleKeydown", search_target: "input" },
            autofocus: true %>
        <button type="button" data-action="click->search#toggle" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors" title="Clear search">
          <%= inline_svg_tag "icons/close.svg", class: "w-4 h-4" %>
        </button>
      </div>
      <%= form.hidden_field :status, value: params[:status] %>
    <% end %>
  </div>
</div>

<%= turbo_frame_tag "stats-content" do %>
  <% if params[:search].present? || params[:status].present? %>
    <div class="bg-slate-50 dark:bg-slate-700/50 border border-slate-200 dark:border-slate-700 rounded-xl px-6 py-3 mb-4 flex items-center gap-3">
      <span class="text-lg font-bold text-slate-900 dark:text-slate-50"><%= @pagy.count %></span>
      <span class="text-sm text-slate-500 dark:text-slate-400"><%= "result".pluralize(@pagy.count) %> for</span>
      <% if params[:status].present? %>
        <% status_label = case params[:status] when "paid" then "Paid" when "comped" then "Comped" end %>
        <%= link_to admin_blogs_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-600 hover:border-slate-400 dark:hover:border-slate-500 transition-colors" do %>
          <%= status_label %>
          <%= inline_svg_tag "icons/close.svg", class: "w-3.5 h-3.5 text-slate-400" %>
        <% end %>
      <% end %>
      <% if params[:search].present? %>
        <%= link_to admin_blogs_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-600 hover:border-slate-400 dark:hover:border-slate-500 transition-colors" do %>
          "<%= params[:search] %>"
          <%= inline_svg_tag "icons/close.svg", class: "w-3.5 h-3.5 text-slate-400" %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-x-auto">
    <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
      <thead>
        <tr class="bg-slate-50 dark:bg-slate-700/50">
          <th class="py-3 px-6 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Name</th>
          <th class="py-3 px-6 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Posts</th>
          <th class="py-3 px-6 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Email</th>
          <th class="py-3 px-6 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Verified</th>
          <th class="py-3 px-6 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Status</th>
          <th class="py-3 px-6 text-end text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
      <% @blogs.each do |blog| %>
        <tr>
          <td class="whitespace-nowrap py-3 px-6 text-sm font-medium text-slate-900 dark:text-slate-50">
            <div class="leading-tight">
              <%= link_to blog.subdomain, admin_user_path(blog.user), class: "font-medium underline", data: { turbo_frame: "_top" } %>
              <div class="text-xs text-slate-400 dark:text-slate-500 font-normal mt-1">
                <%= link_to blog_home_url(blog), blog_home_url(blog), class: "hover:underline", target: "_blank" %>
              </div>
            </div>
          </td>
          <td class="whitespace-nowrap py-3 px-6 text-sm text-slate-500 dark:text-slate-400"><%= number_with_delimiter blog.posts_count %></td>
          <td class="whitespace-nowrap py-3 px-6 text-sm text-slate-500 dark:text-slate-400"><!--email_off--><%= blog.user.email %><!--/email_off--></td>
          <td class="whitespace-nowrap py-3 px-6 text-sm text-slate-500 dark:text-slate-400"><%= blog.user.verified? ? '✅' : '❌' %></td>
          <td class="whitespace-nowrap py-3 px-6 text-sm">
            <% if blog.user.discarded_at %>
              <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400">Cancelled</span>
            <% elsif blog.user.subscribed? %>
              <% if blog.user.subscription.complimentary? %>
                <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">Comped</span>
              <% else %>
                <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400">Premium</span>
              <% end %>
            <% else %>
              <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300">Free</span>
              <% if blog.user.subscribed? && blog.user.lapsed? %>
                <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">Lapsed</span>
              <% end %>
            <% end %>
          </td>
          <td class="whitespace-nowrap py-3 px-6 text-sm text-slate-500 dark:text-slate-400 text-end">
            <span class="hidden sm:inline"><%= blog.created_at.strftime("%-d %b %Y %H:%M") %></span>
            <span class="sm:hidden"><%= blog.created_at.strftime("%-d %b %Y") %></span>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>

  <%= render "app/shared/pagy_nav" %>
<% end %>
