<% nav_help = capture do %>
  <%= render "app/shared/dialog",
    id: "navigation-help",
    title: "Navigation Quick Start",
    button_label: "Navigation help",
    shortcut: "?",
    content_partial: "app/shared/help/navigation_content" %>
<% end %>

<div class="space-y-8">
  <%= settings_section "Navigation", description: "Links in your blog's header. Drag to reorder.", control: nav_help do %>
    <% if @navigation_items.any? %>
      <div data-controller="sortable"
           data-sortable-resource-name-value="navigation_item"
           data-sortable-handle-value=".handle"
           data-sortable-animation-value="150">
        <% @navigation_items.each do |item| %>
          <%= render partial: item.class.name.underscore, locals: { item.class.name.underscore.to_sym => item } %>
        <% end %>
      </div>
    <% else %>
      <p class="px-6 py-5 text-slate-500 dark:text-slate-400">
        No navigation links yet. Add one below.
      </p>
    <% end %>
  <% end %>

  <%= settings_section "Add a link" do %>
    <div class="px-6 py-5" data-controller="navigation-form" data-navigation-form-rss-feed-url-value="<%= rss_feed_url(@blog) %>">
      <%= form_with model: [:app, :settings, @navigation_item || NavigationItem.new], scope: :navigation_item, url: @navigation_item&.persisted? ? app_settings_navigation_item_path(@navigation_item) : app_settings_navigation_items_path, class: "space-y-6" do |form| %>
        <div>
          <div class="space-y-3">
            <% selected_type = if @navigation_item.nil? || @navigation_item.is_a?(PageNavigationItem)
                 "page"
               elsif @navigation_item.is_a?(SocialNavigationItem)
                 "social"
               elsif @navigation_item.is_a?(SearchNavigationItem)
                 "search"
               else
                 "custom"
               end %>
            <label class="flex items-center">
              <%= radio_button_tag :nav_type, "page", selected_type == "page",
                  class: "rounded-full border-slate-300 dark:border-slate-600 text-[#4fbd9c] focus:ring-[#4fbd9c]",
                  data: { navigation_form_target: "pageRadio", action: "change->navigation-form#toggleFields" } %>
              <span class="ml-2">Link to a page</span>
            </label>
            <label class="flex items-center">
              <%= radio_button_tag :nav_type, "custom", selected_type == "custom",
                  class: "rounded-full border-slate-300 dark:border-slate-600 text-[#4fbd9c] focus:ring-[#4fbd9c]",
                  data: { navigation_form_target: "customRadio", action: "change->navigation-form#toggleFields" } %>
              <span class="ml-2">Custom link</span>
            </label>
            <label class="flex items-center">
              <%= radio_button_tag :nav_type, "social", selected_type == "social",
                  class: "rounded-full border-slate-300 dark:border-slate-600 text-[#4fbd9c] focus:ring-[#4fbd9c]",
                  data: { navigation_form_target: "socialRadio", action: "change->navigation-form#toggleFields" } %>
              <span class="ml-2">Social link</span>
            </label>
            <% if @blog.user.has_premium_access? && (@navigation_item.is_a?(SearchNavigationItem) || !@blog.navigation_items.exists?(type: "SearchNavigationItem")) %>
              <label class="flex items-center">
                <%= radio_button_tag :nav_type, "search", selected_type == "search",
                    class: "rounded-full border-slate-300 dark:border-slate-600 text-[#4fbd9c] focus:ring-[#4fbd9c]",
                    data: { navigation_form_target: "searchRadio", action: "change->navigation-form#toggleFields" } %>
                <span class="ml-2">Search</span>
              </label>
            <% end %>
          </div>
        </div>

        <div data-navigation-form-target="pageFields" class="<%= 'hidden' if selected_type != 'page' %>">
          <%= form.label :post_id, "Page", class: "block font-medium mb-2" %>
          <%= form.select :post_id,
              options_from_collection_for_select(@pages, :id, :title),
              { include_blank: "Select a page..." },
              class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200" %>
        </div>

        <div data-navigation-form-target="customFields" class="space-y-4 <%= 'hidden' if selected_type != 'custom' %>">
          <fieldset>
            <%= form.label :label, "Label", class: "block font-medium mb-2" %>
            <%= form.text_field :label,
                placeholder: "e.g., Posts, Archive, Blog",
                class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200" %>
            <div class="field-error"><%= @navigation_item.errors[:label].to_sentence if @navigation_item&.errors&.[](:label)&.any? %></div>
          </fieldset>

          <fieldset>
            <%= form.label :url, "URL", class: "block font-medium mb-2" %>
            <%= form.text_field :url,
                placeholder: "e.g., /posts, /archive, https://example.com",
                class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200" %>
            <div class="field-error"><%= @navigation_item.errors[:url].to_sentence if @navigation_item&.errors&.[](:url)&.any? %></div>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
              Use relative paths (e.g., /posts) or full URLs (https://...)
            </p>
          </fieldset>
        </div>

        <div data-navigation-form-target="socialFields" class="space-y-4 <%= 'hidden' if selected_type != 'social' %>">
          <fieldset>
            <%= form.label :platform, "Platform", class: "block font-medium mb-2" %>
            <%= form.select :platform,
                options_for_select(SocialNavigationItem::PLATFORMS, @navigation_item&.platform),
                { include_blank: "Select platform..." },
                class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200",
                data: { navigation_form_target: "platform", action: "change->navigation-form#handlePlatformChange" } %>
            <div class="field-error"><%= @navigation_item.errors[:platform].to_sentence if @navigation_item&.errors&.[](:platform)&.any? %></div>
          </fieldset>

          <fieldset>
            <%= form.label :url, "URL", class: "block font-medium mb-2", for: "navigation_item_social_url" %>
            <%= form.text_field :url,
                id: "navigation_item_social_url",
                placeholder: "https://...",
                class: "w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200",
                data: { navigation_form_target: "url" } %>
            <div class="field-error"><%= @navigation_item.errors[:url].to_sentence if @navigation_item&.errors&.[](:url)&.any? %></div>
          </fieldset>
        </div>

        <div data-navigation-form-target="searchFields" class="<%= 'hidden' if selected_type != 'search' %>">
          <%= form.hidden_field :label, value: "Search" %>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            Adds a search icon to your navigation, linking to your blog's search page.
          </p>
        </div>

        <div>
          <%= form.submit "Add to Navigation", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
