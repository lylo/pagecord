<section class="-mx-4 overflow-hidden border-y border-slate-200 bg-white sm:mx-0 sm:rounded-lg sm:border dark:border-slate-700 dark:bg-slate-900">
  <div class="flex items-start justify-between gap-4 border-b border-slate-200 bg-slate-50 px-4 py-5 sm:px-6 dark:border-slate-700 dark:bg-slate-800">
    <div>
      <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100"><%= title %></h3>
      <% if description %>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400"><%= description %></p>
      <% end %>
    </div>
    <%= control if control %>
  </div>

  <div class="divide-y divide-slate-200 dark:divide-slate-700">
    <%= yield %>
  </div>
</section>
