<h2 class="text-2xl font-bold mb-2">Theme Garden</h2>
<p class="text-slate-500 dark:text-slate-400 mb-8">
  Browse curated CSS templates and apply them to your blog with one click.
  Have a theme you'd like to share? <a href="mailto:hello@pagecord.com" class="underline">Send it to us</a>.
</p>

<% unless @blog.user.has_premium_access? %>
  <div class="mb-8">
    <%= callout(:info) do %>
      <%= link_to "Subscribe", app_settings_subscriptions_path, class: "underline font-medium" %> or start a free trial to apply templates to your blog.
    <% end %>
  </div>
<% end %>

<% if @templates.any? %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @templates.each do |template| %>
      <div class="border border-slate-200 dark:border-slate-700 rounded-lg overflow-hidden hover:shadow-md transition-shadow">
        <% if template.screenshot.attached? %>
          <%= image_tag resized_image_url(template.screenshot, width: 600, height: 400), class: "w-full h-48 object-cover object-top", alt: template.name %>
        <% else %>
          <div class="w-full h-48 bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
            <span class="text-slate-400 dark:text-slate-600 text-sm">No preview</span>
          </div>
        <% end %>

        <div class="p-4">
          <h3 class="font-bold text-lg mb-1"><%= template.name %></h3>
          <% if template.description.present? %>
            <p class="text-slate-500 dark:text-slate-400 text-sm mb-3"><%= template.description %></p>
          <% end %>

          <% if template.author_name.present? %>
            <p class="text-xs text-slate-400 dark:text-slate-500 mb-3">
              By
              <% if template.author_url.present? %>
                <%= link_to template.author_name, template.author_url, class: "underline", target: "_blank" %>
              <% else %>
                <%= template.author_name %>
              <% end %>
            </p>
          <% end %>

          <div class="flex gap-2">
            <%= link_to "Preview", preview_app_settings_theme_garden_path(template), class: "btn-secondary text-sm", target: "_blank" %>
            <% if @blog.user.has_premium_access? %>
              <% confirm_message = @blog.custom_css.present? ? "This will replace your current Custom CSS and appearance settings. Continue?" : nil %>
              <%= button_to "Apply", apply_app_settings_theme_garden_path(template), class: "btn-primary text-sm", form: { data: { turbo_confirm: confirm_message } } %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-slate-500 dark:text-slate-400">No templates available yet. Check back soon!</p>
<% end %>

<div class="mt-12 border-t border-t-slate-200 dark:border-slate-600 pt-4">
  <%= link_to "Back to Appearance", app_settings_appearance_index_path, class: "btn-secondary" %>
</div>
