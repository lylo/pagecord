<%= form_with url: app_settings_blog_path(@blog), model: @blog do |form| %>
  <% disabled = !@blog.user.subscribed? %>

  <div class="space-y-8">
    <%= settings_section "Blog Settings" do %>
      <%= settings_row "Post by Email" do %>
        <p class="text-slate-700 dark:text-slate-300">
          Send an email from <%= @blog.user.email %> to
          <%= mail_to @blog.delivery_email, class: "font-semibold underline" %> to publish a new post on this blog.
        </p>
      <% end %>

      <%= settings_row "Custom Domain" do %>
        <div class="space-y-4">
          <% if disabled %>
            <%= callout(:info) do %>
              <%= link_to "Subscribe", app_settings_subscriptions_path, class: "underline font-medium" %> to use your own domain for your blog.
            <% end %>
          <% elsif @blog.custom_domain.present? && @blog.errors[:custom_domain].empty? %>
            <p class="text-slate-700 dark:text-slate-300">
              Your Pagecord is now available at <code><mark class="bg-slate-100 px-1 dark:bg-slate-700 dark:text-slate-100"><%= @blog.custom_domain %></mark></code>
            </p>
          <% end %>

          <fieldset>
            <%= styled_text_field(form, :custom_domain, placeholder: "yourdomain.com", class: "md:w-80", disabled: disabled) %>
            <%= field_error(@blog, :custom_domain) %>
          </fieldset>
        </div>

        <% unless disabled %>
          <% if @blog.custom_domain.present? && @blog.errors[:custom_domain].empty? %>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
              To remove your custom domain, clear the box above and click Update. Don't forget to remove the records from your DNS!
            </p>
          <% else %>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
              You'll need to configure your DNS first – read <a href="https://help.pagecord.com/custom-domains" class="font-medium underline">the help guide</a> for details.
            </p>
          <% end %>
        <% end %>
      <% end %>

      <%= settings_row "Language" do %>
        <fieldset>
          <%= render "language_select", form: form %>
          <%= field_error(@blog, :locale) %>
        </fieldset>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
          Used for subscription forms and interface copy on your blog.
        </p>
      <% end %>

      <%= settings_row "Links" do %>
        <div class="flex gap-3">
          <div class="flex h-6 shrink-0 items-center">
            <%= styled_check_box form, :external_links_in_new_tab, checked: @blog.external_links_in_new_tab %>
          </div>
          <div>
            <%= form.label :external_links_in_new_tab, "Open external links in a new tab", class: "text-slate-800 dark:text-slate-100" %>
          </div>
        </div>
      <% end %>

      <%= settings_row "Discoverability" do %>
        <div class="flex gap-3">
          <div class="flex h-6 shrink-0 items-center">
            <%= styled_check_box form, :allow_search_indexing, checked: @blog.allow_search_indexing %>
          </div>
          <div>
            <%= form.label :allow_search_indexing, "Make my blog discoverable", class: "text-slate-800 dark:text-slate-100" %>
            <p class="mt-1 text-slate-500 text-sm">
              When unticked, we'll serve a <tt>/robots.txt</tt> that discourages search engines, and exclude your blog from the Pagecord Spotlight and Shuffle.
            </p>
          </div>
        </div>
      <% end %>
    <% end %>

    <%= settings_section "Advanced", description: "Optional settings most blogs won't need to change" do %>
      <%= settings_row "SEO Blog Title" do %>
        <fieldset>
          <%= styled_text_field(form, :seo_title, placeholder: "e.g. #{@blog.display_name} - Personal Blog", class: "md:w-full") %>
          <%= field_error(@blog, :seo_title) %>
        </fieldset>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
          Overrides your blog name in the HTML title used by search engines and social sharing.
        </p>
      <% end %>

      <%= settings_row "Fediverse Author Attribution" do %>
        <%= styled_text_field(form, :fediverse_author_attribution, placeholder: "e.g. @you@mastodon.social", class: "md:w-full") %>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
          Your full Fediverse handle, not your profile URL. Mastodon will show you as the author when someone shares one of your posts.
        </p>
      <% end %>

      <%= settings_row "Identity Links (rel=me)" do %>
        <fieldset>
          <%= form.text_area :rel_me_links,
              rows: 4,
              placeholder: "https://mastodon.social/@you\nhttps://github.com/you",
              class: "form-field md:w-full font-mono text-sm" %>
          <%= field_error(@blog, :rel_me_links) %>
        </fieldset>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
          Links to your profiles elsewhere on the web, one per line. Services like Mastodon, Threads and IndieAuth use these to verify that this blog is yours – your profile there must also link back to this blog. Leave blank to use your social navigation links on services that support verification.
        </p>
      <% end %>

      <%= settings_row "Google Site Verification" do %>
        <fieldset>
          <%= styled_text_field(form, :google_site_verification, placeholder: "e.g. Gzm-PA_FXh231_cgsIxY_h9OgR6r8DZ", class: "md:w-full", data: { controller: "google-site-verification", action: "paste->google-site-verification#paste" }) %>
          <%= field_error(@blog, :google_site_verification) %>
        </fieldset>
        <% if @blog.google_site_verification.present? %>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
            To remove your Google site verification, clear the box above and click Update.
          </p>
        <% else %>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
            Adds a <code>google-site-verification</code> meta tag to your blog's HTML.
          </p>
        <% end %>
      <% end %>

      <%= settings_row "Blog Subdomain" do %>
        <p class="mb-4 text-slate-700 dark:text-slate-300">
          Your current blog subdomain is <strong><%= persisted_value(@blog, :subdomain) %></strong> which means your blog is available at <span class="bg-slate-100 px-1 dark:bg-slate-700">https://<%= persisted_value(@blog, :subdomain) %>.pagecord.com</span>.
        </p>

        <div class="mb-4">
          <%= callout(:warning) do %>
            <strong>Warning:</strong> Changing your blog subdomain changes the URL of your blog, so any links to your old blog URL will no longer work!
          <% end %>
        </div>

        <fieldset>
          <%= form.label :subdomain, "Subdomain", class: "sr-only" %>
          <%= styled_text_field(form, :subdomain, required: true, placeholder: "subdomain", maxlength: 20, class: "md:w-80") %>
          <%= field_error(@blog, :subdomain) %>
        </fieldset>
      <% end %>
    <% end %>
  </div>

  <div class="mt-12 flex items-center gap-x-2 border-t border-t-slate-200 pt-4 dark:border-slate-600">
    <%= form.submit "Update", class: "btn-primary" %>
    <%= link_to "Cancel", app_settings_path, class: "btn-secondary" %>
  </div>
<% end %>
