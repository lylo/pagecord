<% has_premium = @blog.user.subscribed? %>
<% saved = @blog.custom_robots_txt.present? %>
<% editor_value = @blog.custom_robots_txt.presence %>
<% editor_value ||= render(partial: "blogs/robots/ai_training_crawlers", formats: :text) if has_premium %>

<div class="group">
  <div class="grid gap-4 px-6 py-5 md:grid-cols-[12rem_1fr]">
    <div>
      <h4 class="font-bold text-slate-900 dark:text-slate-100">Crawler Rules</h4>
    </div>
    <div>
      <p class="text-slate-700 dark:text-slate-300">
        <% if has_premium %>
          Customise the crawler rules section of your blog's <tt>robots.txt</tt> – for example, to unblock an AI crawler. The default rules (search engine access and your sitemap) always apply and can't be changed.
        <% else %>
          Customising crawler rules is available with a subscription.
        <% end %>
      </p>

      <div class="mt-6 flex gap-3 <%= 'opacity-50' unless has_premium %>">
        <div class="flex h-6 shrink-0 items-center">
          <%= check_box_tag :use_custom_robots_txt,
              "1",
              has_premium && saved,
              disabled: !has_premium,
              class: "form-checkbox h-5 w-5 text-slate-600 border-slate-300 dark:border-slate-600 dark:bg-slate-700 rounded focus:ring focus:ring-slate-300 dark:focus:ring-slate-600 focus:ring-offset-0 disabled:cursor-not-allowed" %>
        </div>
        <div>
          <%= label_tag :use_custom_robots_txt, "Use custom crawler rules", class: "text-slate-800 dark:text-slate-100" %>
        </div>
      </div>

      <% if saved %>
        <p class="hidden group-has-[input:not(:checked)]:block mt-2 text-sm text-amber-600 dark:text-amber-400">
          Note: Unchecking this box and saving will restore Pagecord's default crawler rules.
        </p>
      <% end %>
    </div>
  </div>

  <div class="hidden group-has-[input:checked]:block px-6 pb-6">
    <%= text_area_tag "blog[custom_robots_txt]",
        editor_value,
        id: "blog_custom_robots_txt",
        rows: 16,
        class: "form-field font-mono text-sm w-full" %>
    <%= field_error(@blog, :custom_robots_txt) %>
  </div>
</div>
