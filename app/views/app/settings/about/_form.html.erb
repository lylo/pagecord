<%= form_with url: app_settings_about_path(@blog), model: @blog, data: { controller: "avatar" } do |form| %>
  <%= settings_section "About", description: "How you're introduced on your blog's home page" do %>
    <%= settings_row "Bio", stacked: true, hint: "Appears in the header of your blog's home page" do %>
      <div class="lexxy-minimal">
        <%= form.rich_text_area :bio,
            placeholder: "add a bio to your profile if you like...",
            class: "lexxy-content focus:ring-0 focus:!border-slate-500 dark:focus:!border-slate-400",
            spellcheck: true,
            autocorrect: "on",
            autocapitalize: "sentences",
            attachments: false,
            autofocus: true,
            data: { controller: "lexxy ios-toolbar", subscribed: false } %>
      </div>

      <div class="field-error"><%= @blog.errors[:bio].first if @blog.errors[:bio].any? %></div>
    <% end %>

    <%= settings_row "Blog Title" do %>
      <%= styled_text_field(form, :title, class: "w-full") %>
      <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
        Shown on your blog instead of <strong>@<%= @blog.subdomain %></strong>.
      </p>
    <% end %>

    <% avatar_disabled = @blog.user.on_free_plan? %>
    <%= settings_row "Avatar" do %>
      <% if avatar_disabled %>
        <div class="mb-4">
          <%= callout(:info) do %>
            <%= link_to "Subscribe", app_settings_subscriptions_path, class: "underline font-medium" %> to add an avatar to your blog.
          <% end %>
        </div>
      <% elsif @blog.user.on_trial? %>
        <div class="mb-4"><%= trial_callout("Avatar") %></div>
      <% end %>

      <div class="<%= 'opacity-50 pointer-events-none' if avatar_disabled %>">
        <div class="text-start flex flex-col" id="blog-avatar">
          <a href="#" data-action="click->avatar#open" title="Update your avatar">
            <%= render "avatar", blog: @blog %>
          </a>
          <% if @blog.avatar&.attached? %>
            <%= link_to app_blog_avatar_path(@blog), data: { turbo_method: :delete }, class: "flex items-center text-sm text-slate-500 hover:text-slate-800 dark:text-slate-400 hover:dark:text-slate-200 p-0 mt-1" do %>
              <%= inline_svg_tag "icons/trash.svg", class: "w-4 h-4 me-1 " %>
              Remove
            <% end %>
          <% end %>
        </div>

        <%= form.file_field :avatar, class: "hidden", accept: "image/jpeg, image/png, image/webp", data: { avatar_target: "input" } %>

        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
          <% if @blog.avatar&.attached? %>
            Click the image to choose a new avatar, or Remove to delete it.
          <% else %>
            Click the icon to choose an avatar, then click Update.
          <% end %>
        </p>
      </div>
    <% end %>
  <% end %>

  <div class="mt-12 flex items-center gap-x-2">
    <%= form.submit "Update", class: "btn-primary" %>
    <%= link_to "Cancel", app_settings_path, class: "btn-secondary" %>
  </div>
<% end %>
