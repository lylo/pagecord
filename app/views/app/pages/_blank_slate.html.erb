<div class="rounded-lg bg-slate-50 p-6 dark:bg-slate-800">
  <div class="max-w-xl">
    <h1 class="text-xl font-semibold text-slate-900 dark:text-slate-50">Pages</h1>
    <p class="mt-3 leading-7 text-slate-600 dark:text-slate-300">
      Create an About page, a Contact page, a Now page, or any other dedicated page on your site.

      You can add these Pages to your site navigation in the <%= link_to "Navigation settings", app_settings_navigation_items_path, class: "font-medium underline decoration-slate-300 underline-offset-2 hover:decoration-slate-500 dark:decoration-slate-600 dark:hover:decoration-slate-300" %>.
    </p>
  </div>

  <div class="mt-5 flex flex-wrap gap-2">
    <%= link_to "✏️ New Page", new_app_page_path, class: "btn-primary", title: "Create a new page" %>
    <% unless @blog.has_custom_home_page? %>
      <%= link_to "🏠 Create Home Page", new_app_home_page_path, class: "btn-secondary", title: "Create a blank home page" %>
    <% end %>
  </div>
</div>
