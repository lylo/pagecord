<div class="mx-auto max-w-2xl w-full text-slate-950 dark:text-slate-50">
  <div class="my-8">
    <div class="mb-8">
      <% if @pages.empty? && @drafts.empty? %>
        <%= render "blank_slate" %>
      <% else %>
        <div class="mb-8 flex flex-wrap justify-end gap-2">
          <% unless @blog.has_custom_home_page? %>
            <%= link_to "🏠 Create Home Page", new_app_home_page_path, class: "btn-secondary", title: "Create a blank home page" %>
          <% end %>
          <%= link_to "✏️ New Page", new_app_page_path, class: "btn-primary", title: "Create a new page" %>
        </div>
      <% end %>
    </div>

    <% if @drafts.any? || @pages.any? %>
      <div class="overflow-hidden rounded-lg border border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-900/60">
        <% if @drafts.any? %>
          <div class="p-4 sm:p-5" id="draft_pages">
            <div class="mb-3 flex items-center gap-2">
              <div class="text-lg font-semibold text-slate-900 dark:text-slate-100">🖋️ Drafts</div>
              <span class="rounded-full bg-slate-200 px-2 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-700 dark:text-slate-300">
                <%= @drafts.size %>
              </span>
            </div>

            <div>
              <% @drafts.each do |page| %>
                <div class="group flex items-center justify-between gap-3 py-1.5">
                  <div class="min-w-0 flex items-center gap-2">
                    <% edit_path = (page.home_page? ? edit_app_home_page_path : edit_app_page_path(page)) %>

                    <%= link_to edit_path, title: "Click to edit this page", class: "min-w-0" do %>
                      <div class="flex items-center gap-2">
                        <% if page.home_page? %>
                          <span>🏠</span>
                        <% end %>
                        <div class="truncate font-medium text-slate-900 group-hover:underline dark:text-slate-100">
                          <%= page.display_title %>
                        </div>
                      </div>
                    <% end %>
                  </div>

                  <div class="flex items-center gap-x-2 text-slate-400 dark:text-slate-400">
                    <%= link_to app_post_path(page), title: "Preview draft", target: "_blank", data: { turbo_frame: "_top" }, class: "transition-colors hover:text-slate-600 dark:hover:text-slate-200" do %>
                      <%= inline_svg_tag "icons/arrow-top-right-on-square.svg", class: "h-4 w-4" %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if @drafts.any? && @pages.any? %>
          <div class="border-t border-slate-200 dark:border-slate-700"></div>
        <% end %>

        <% if @pages.any? %>
          <div class="p-4 sm:p-5">
            <div class="mb-3 flex flex-wrap items-center justify-between gap-3">
              <div class="flex items-center gap-2">
                <div class="text-lg font-semibold text-slate-900 dark:text-slate-100">📄 Pages</div>
                <span class="rounded-full bg-slate-200 px-2 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-700 dark:text-slate-300">
                  <%= @pages.size %>
                </span>
              </div>

              <div class="inline-flex items-center rounded-lg border border-slate-200 bg-slate-50 p-1 text-sm dark:border-slate-700 dark:bg-slate-800/80">
                <%= link_to app_pages_path(sort: "alpha"),
                      title: "Sort alphabetically",
                      aria: { current: (@sort == "alpha" ? "page" : nil) },
                      class: @sort == "alpha" ? "inline-flex items-center gap-1.5 rounded-md bg-white px-3 py-1.5 font-medium text-slate-900 dark:bg-slate-700 dark:text-slate-50" : "inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-slate-500 transition-colors hover:bg-white hover:text-slate-700 dark:text-slate-400 dark:hover:bg-slate-700 dark:hover:text-slate-200" do %>
                  <%= inline_svg_tag "icons/bars-arrow-down.svg", class: "h-4 w-4 shrink-0" %>
                  <span>A–Z</span>
                <% end %>

                <%= link_to app_pages_path(sort: "updated"),
                      title: "Sort by recently updated",
                      aria: { current: (@sort == "updated" ? "page" : nil) },
                      class: @sort == "updated" ? "inline-flex items-center gap-1.5 rounded-md bg-white px-3 py-1.5 font-medium text-slate-900 dark:bg-slate-700 dark:text-slate-50" : "inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-slate-500 transition-colors hover:bg-white hover:text-slate-700 dark:text-slate-400 dark:hover:bg-slate-700 dark:hover:text-slate-200" do %>
                  <%= inline_svg_tag "icons/clock.svg", class: "h-4 w-4 shrink-0" %>
                  <span>Recent</span>
                <% end %>
              </div>
            </div>

            <div>
              <% @pages.each do |page| %>
                <div class="group flex items-center justify-between gap-3 py-1.5">
                  <div class="min-w-0 flex items-center gap-2">
                    <% edit_path = page.home_page? ? edit_app_home_page_path : edit_app_page_path(page) %>

                    <%= link_to edit_path, title: "Click to edit this page", class: "min-w-0" do %>
                      <div class="flex items-center gap-2">
                        <% if page.home_page? %>
                          <span title="This page is your home page">🏠</span>
                        <% end %>
                        <div class="truncate font-medium text-slate-900 group-hover:underline dark:text-slate-100">
                          <%= page.display_title %>
                        </div>
                      </div>
                    <% end %>
                  </div>

                  <div class="flex items-center gap-x-2 text-slate-400 dark:text-slate-400">
                    <%= link_to post_url(page), title: "View this page", target: "_blank", class: "transition-colors hover:text-slate-600 dark:hover:text-slate-200" do %>
                      <%= inline_svg_tag "icons/arrow-top-right-on-square.svg", class: "h-4 w-4" %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% trashed_count = Current.user.blog.pages.discarded.count %>
    <% if trashed_count > 0 %>
      <div class="mt-8 pt-4 border-t border-slate-200 dark:border-slate-700">
        <%= link_to app_pages_trash_index_path, class: "inline-flex items-center gap-1.5 text-sm text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300" do %>
          <%= inline_svg_tag "icons/trash.svg", class: "w-3.5 h-3.5" %>
          <%= pluralize trashed_count, "deleted page" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
