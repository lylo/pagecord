<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold">Your blogs</h1>
    <% if Current.user.subscribed? && @blogs.count < Current.user.blog_limit %>
      <%= link_to "New blog", new_app_blog_path, class: "btn-primary text-sm" %>
    <% end %>
  </div>

  <% unless Current.user.subscribed? %>
    <%= callout(:info) do %>
      <%= link_to "Subscribe to Pagecord Premium", app_settings_subscriptions_path, class: "underline font-medium" %> to add a second blog to your account. Handy for a separate photo blog or microblog!
    <% end %>
  <% end %>

  <div class="space-y-3">
    <% @blogs.each do |blog| %>
      <div class="flex items-center justify-between p-4 border rounded-lg <%= blog.id == @blog.id ? 'border-[#4fbd9c]/40 bg-[#4fbd9c]/5 dark:border-[#4fbd9c]/30 dark:bg-[#4fbd9c]/10' : 'border-slate-200 dark:border-slate-700' %>">
        <div class="flex items-center gap-3">
          <%= render "app/shared/blog_avatar", blog: blog, size: "md" %>
          <div>
            <div class="font-medium"><%= blog.display_name %></div>
            <div class="text-sm text-slate-500"><%= blog.subdomain %>.pagecord.com · <%= pluralize(blog.posts.count, "post") %></div>
          </div>
        </div>

        <% if @blogs.count > 1 %>
          <% confirm_message = "Are you sure you want to delete #{blog.display_name}?" %>
          <%= button_to app_blog_path(blog), method: :delete,
              class: "btn-danger",
              form: { data: { turbo_confirm: confirm_message } } do %>
            Delete
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% trashed_count = Current.user.all_blogs.discarded.count %>
  <% if trashed_count > 0 %>
    <div class="pt-4 border-t border-slate-200 dark:border-slate-700">
      <%= link_to app_blogs_trash_path, class: "inline-flex items-center gap-1.5 text-sm text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300" do %>
        <%= inline_svg_tag "icons/trash.svg", class: "w-3.5 h-3.5" %>
        <%= pluralize trashed_count, "deleted blog" %>
      <% end %>
    </div>
  <% end %>
</div>
