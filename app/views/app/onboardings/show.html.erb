<div class="mt-8 prose dark:prose-invert">
  <h1 class="text-2xl sm:text-3xl">
  Welcome to Pagecord! ✨
  </h1>

  <p>
    Your blog is now live on the web at <%= link_to blog_home_url(@blog), blog_home_url(@blog), class: "font-semibold underline" %>
  </p>

  <p>
    To help you get started, we're going to set a few things up. You don't need to decide now &ndash; you can
    change any of this later in your Settings!
  </p>

  <h2 class="text-xl sm:text-2xl">
    Give your blog a custom title
  </h2>

  <p>
    If you like, you can give your blog a different title to <span class="font-bold">@<%= @blog.subdomain %></span>. Just enter it below and click Save.
  </p>

  <%= form_with url: app_onboarding_path, model: @blog,
        data: {
          turbo_scroll: false,
          controller: "save-button",
          action: "turbo:submit-end->save-button#showMessage"
        } do |form| %>
    <fieldset>
      <%= form.text_field :title, placeholder: "Enter a new title...", class: "w-full dark:bg-slate-800 border border-slate-300 dark:border-slate-700 text-slate-800 dark:text-slate-200 rounded-lg" %>
      <div class="field-error"><%= @blog.errors[:title].first if @blog.errors[:title].any? %></div>
    </fieldset>

    <%= form.submit "Save",
      data: {
        save_button_target: "button",
        save_button_message_value: "✅ Saved!"
      },
      class: "mt-2 btn-primary"
    %>
  <% end %>

  <h2 class="text-xl sm:text-2xl">
    Add a bio
  </h2>

  <p>
    Your bio will appear at the top of your blog's home page. This is where you'll tell the world all about your blog! It's entirely optional,
    and you can always add one later.
  </p>

  <div class="lexxy-minimal">
    <%= form_with url: app_onboarding_path, model: @blog,
          data: {
            turbo_scroll: false,
            controller: "save-button",
            action: "turbo:submit-end->save-button#showMessage"
          } do |form| %>

      <fieldset>
        <%= form.rich_text_area :bio,
          placeholder: "add a bio to your profile if you like...",
          class: "lexxy-content min-h-[150px] border-slate-300 dark:border-slate-600 text-slate-800 dark:text-slate-200 rounded-lg",
          spellcheck: true,
          autocorrect: "on",
          autocapitalize: "sentences",
          attachments: false,
          data: { controller: "autogrow", subscribed: false } %>

        <div id="bio_error" class="field-error"><%= render "bio_error" if @blog.errors[:bio].any? %></div>
      </fieldset>

      <%= form.submit "Save",
        data: { save_button_target: "button" },
        class: "mt-2 btn-primary"
      %>
    <% end %>
  </div>

  <h2 class="text-xl sm:text-2xl">
    Choose a design ✨
  </h2>
  <p>
    Start from a ready-made design, or set the basics yourself. You can always change any of this later in Appearance settings.
  </p>

  <div data-controller="tabs" class="not-prose my-6">
    <div class="flex gap-1 p-1 rounded-xl bg-slate-100 dark:bg-slate-800">
      <button type="button"
        data-tabs-target="tab"
        data-action="tabs#select"
        data-tabs-index-param="0"
        class="flex-1 px-4 py-3 rounded-lg text-sm sm:text-base font-bold cursor-pointer transition bg-white dark:bg-slate-900 text-slate-900 dark:text-white shadow-sm">
        🖼️ Ready-made design
      </button>
      <button type="button"
        data-tabs-target="tab"
        data-action="tabs#select"
        data-tabs-index-param="1"
        class="flex-1 px-4 py-3 rounded-lg text-sm sm:text-base font-bold cursor-pointer transition text-slate-500 dark:text-slate-400">
        🎛️ Start with the basics
      </button>
    </div>

    <div data-tabs-target="panel" class="pt-6">
      <%= render "ready_made", templates: @featured_templates %>
    </div>

    <div data-tabs-target="panel" class="hidden pt-6 space-y-8">
      <div>
        <h3 class="text-lg font-semibold">Pick a colour scheme 🎨</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">The default is the classic Pagecord minimal monochrome.</p>
        <%= form_with url: app_onboarding_path, model: @blog, data: { controller: "radio-button-auto-submit" } do |form| %>
          <%= render "/app/settings/appearance/theme_colour", form: form %>
        <% end %>
      </div>

      <div>
        <h3 class="text-lg font-semibold">Choose a typeface</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">Choose whether you'd like a sans-serif font, or serif for that elegant look.</p>
        <%= form_with url: app_onboarding_path, model: @blog, data: { controller: "radio-button-auto-submit" } do |form| %>
          <%= render "/app/settings/appearance/theme_font", form: form %>
        <% end %>
      </div>

      <div>
        <h3 class="text-lg font-semibold">Choose your blog layout</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">The default is a stream of all your posts on the home page. You can also choose a list of post titles and dates, or cards with excerpts.</p>
        <%= form_with url: app_onboarding_path, model: @blog, data: { controller: "radio-button-auto-submit" } do |form| %>
          <%= render "/app/settings/appearance/layout_options", form: form %>
        <% end %>
      </div>

      <div>
        <h3 class="text-lg font-semibold">Choose a page width</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">Choose whether you'd like the standard layout, or one that's wider or narrower.</p>
        <%= form_with url: app_onboarding_path, model: @blog, data: { controller: "radio-button-auto-submit" } do |form| %>
          <%= render "/app/settings/appearance/layout_width", form: form %>
        <% end %>
      </div>
    </div>
  </div>

  <h2 class="text-xl sm:text-2xl">
    Choose your language
  </h2>
  <p>
    Choose the language for your email subscription form and other interface elements.
  </p>

  <%= form_with url: app_onboarding_path, model: @blog, data: { controller: "select-auto-submit" } do |form| %>
    <%= render "/app/settings/blogs/language_select", form: form %>
  <% end %>

  <h2 class="text-xl sm:text-2xl">
    Ready to write ✍️
  </h2>

  <p>
    That's the setup done. Next you'll land on your Posts page, where you can publish your first post &ndash; write it in the editor, from Obsidian, or straight from your inbox.
  </p>

  <div class="flex justify-center">
    <%= button_to complete_app_onboarding_path, class: "text-lg btn-primary my-8" do %>
      Go to your blog and start writing →
    <% end %>
  </div>
</div>
