<div class="rounded-xl border border-slate-200 bg-slate-50 p-6 sm:p-8 dark:border-slate-700 dark:bg-slate-800/50">
  <h1 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-50">Write your first post ✨</h1>
  <p class="mt-2 leading-7 text-slate-600 dark:text-slate-300">
    Your posts will appear here. The quickest way to get started is to compose a draft in the editor. Click the button below to try it out.
  </p>
  <div class="mt-5">
    <%= link_to "✏️ New Post", new_app_post_path, class: "btn-primary", title: "Start writing a new post" %>
  </div>

  <h2 class="mt-8 text-xs font-medium uppercase tracking-wider text-slate-400 dark:text-slate-500">Or publish from</h2>

  <ul class="mt-3 divide-y divide-slate-200 border-t border-slate-200 dark:divide-slate-700 dark:border-slate-700">
    <li class="flex items-start gap-3 py-4">
      <span class="text-xl leading-6" aria-hidden="true">💎</span>
      <div>
        <p class="font-semibold text-slate-900 dark:text-slate-50">Obsidian</p>
        <p class="mt-0.5 text-sm leading-6 text-slate-600 dark:text-slate-300">Publish straight from your vault with the <%= link_to "Pagecord Obsidian plugin", "https://help.pagecord.com/obsidian", target: "_blank", class: "font-medium underline decoration-slate-300 underline-offset-2 hover:text-slate-700 dark:decoration-slate-600 dark:hover:text-slate-300" %>.</p>
      </div>
    </li>
    <li class="flex items-start gap-3 py-4">
      <span class="text-xl leading-6" aria-hidden="true">✉️</span>
      <div>
        <p class="font-semibold text-slate-900 dark:text-slate-50">Email</p>
        <p class="mt-0.5 text-sm leading-6 text-slate-600 dark:text-slate-300"><%= link_to "Email a post", "https://help.pagecord.com/posting-by-email", class: "font-medium underline decoration-slate-300 underline-offset-2 hover:text-slate-700 dark:decoration-slate-600 dark:hover:text-slate-300" %> from your inbox to <%= mail_to @blog.delivery_email, @blog.delivery_email, class: "font-medium underline decoration-slate-300 underline-offset-2 hover:text-slate-700 dark:decoration-slate-600 dark:hover:text-slate-300" %>.</p>
      </div>
    </li>
  </ul>
</div>
