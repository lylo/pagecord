<div class="rounded-lg bg-slate-50 p-6 dark:bg-slate-800">
  <div class="max-w-xl">
    <h1 class="text-xl font-semibold text-slate-900 dark:text-slate-50">Posts</h1>
    <p class="mt-3 leading-7 text-slate-600 dark:text-slate-300">
      You'll see your posts here once you start posting ✨
    </p>
    <p class="mt-4 break-words leading-7 text-slate-600 dark:text-slate-300">
      To publish a new post, send an email from <%= @blog.user.email %> to <%= mail_to @blog.delivery_email, class: "font-semibold underline" %> or click the New Post button.
    </p>
  </div>

  <div class="mt-5 flex flex-wrap gap-2">
    <%= link_to "✏️ New Post", new_app_post_path, class: "btn-primary", title: "Start writing a new post" %>
  </div>
</div>
