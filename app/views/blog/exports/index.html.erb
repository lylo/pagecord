<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title><%= blog.display_name %></title>
</head>
<body>
  <% navigation_items = blog.navigation_items.ordered.reject { |i| i.is_a?(SocialNavigationItem) } %>
  <% if navigation_items.any? %>
    <ul>
    <% navigation_items.each do |item| %>
      <% if item.is_a?(PageNavigationItem) %>
        <li class="page"><a href="<%= item.post.slug %>.html"><%= item.label %></a></li>
      <% else %>
        <li class="page"><a href="<%= item.url %>"><%= item.label %></a></li>
      <% end %>
    <% end %>
    </ul>
  <% end %>

  <h1><%= blog.display_name %></h1>
  <% if blog.bio -%>
  <div><%= blog.bio %></div>
  <% end -%>
  <% current_year = nil -%>
  <% blog.posts.visible.order(published_at: :desc).each do |post| -%>
    <% year = post.published_at.year -%>
    <% if year != current_year -%>
      <%= "</ul>".html_safe if current_year -%>
      <h2><%= year %></h2>
      <ul>
      <% current_year = year -%>
    <% end -%>
    <li class="post">
      <%= post.published_at.strftime("%d %b") %> &mdash;
      <a href="<%= post.slug %>.html"><%= post.display_title %></a>
    </li>
  <% end -%>
  <% if blog.posts.any? -%>
    </ul>
  <% end -%>
</body>
</html>