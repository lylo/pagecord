<div class="titlebar avatar-container h-card p-author">
  <% if @blog.avatar&.attached? && @blog.user.has_premium_access? %>
    <div class="avatar">
      <%= link_to blog_home_url(@blog), class: "u-url", aria: { label: "#{@blog.title} Home" } do %>
        <%= image_tag resized_image_url(@blog.avatar, width: 160, height: 160), alt: "#{@blog.title} Avatar", class: "u-photo" %>
      <% end %>
    </div>
  <% end %>

  <%= render "blogs/title" %>
</div>