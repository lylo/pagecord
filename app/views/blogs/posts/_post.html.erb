<% cache_if(post.post?, [post, @blog.updated_at]) do %>
  <article class="<%= post.page? ? 'page' : 'post' %> h-entry">
    <%= render "post_title", post: post %>

    <%= render "post_content", post: post %>

    <%= render "post_footer", post: post if post.post? %>
    <%= render "tags", post: post if post.page? && post.tag_list.present? %>
  </article>
<% end %>
