<% cache_if(post.post?, [post, @blog.updated_at, local_assigns[:summary]]) do %>
  <article class="<%= post.page? ? 'page' : 'post' %> h-entry">
    <%= render "post_title", post: post %>

    <%= render "post_content", post: post, summary: local_assigns[:summary] %>

    <%= render "post_footer", post: post if post.post? %>
  </article>
<% end %>
